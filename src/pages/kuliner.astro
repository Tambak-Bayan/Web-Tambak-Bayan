---
import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <BaseHead title="Kuliner - Tambak Bayan GO-WEB" description="Menu dan warung di Kampung Tambak Bayan." />
  </head>
  <body class="font-sans antialiased text-gray-800 min-h-screen" style="background-color: #FABD32; background-image: radial-gradient(#F59E0B 1px, transparent 1px); background-size: 20px 20px;">
    <div id="navbar-container">
      <Navbar />
    </div>
    <main class="max-w-4xl mx-auto px-4 pb-20 pt-8 relative overflow-hidden">

      <div class="absolute top-40 left-0 text-white/20 font-logo text-4xl -rotate-12 select-none pointer-events-none z-0 max-md:hidden">我们买吧!</div>
      <div class="absolute top-[30rem] right-10 text-white/20 font-logo text-4xl rotate-12 select-none pointer-events-none z-0 max-md:hidden">好的;D</div>
      <div class="absolute bottom-1/4 left-10 text-white/20 font-logo text-4xl -rotate-6 select-none pointer-events-none z-0 max-md:hidden">填充^^</div>
      <div class="absolute bottom-[10rem] right-20 text-white/20 font-logo text-4xl rotate-3 select-none pointer-events-none z-0 max-md:hidden">我们买吧!</div>

      <style>
        .plate-pattern {
          position: relative;
          border-radius: 9999px;
          background-color: #CF2A2A;
          display: flex;
          align-items: center;
          justify-content: center;
          box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
          border: 4px solid #b91c1c;
          outline: 4px dashed #FABD32;
          outline-offset: -8px;
        }
        .menu-card {
          background-color: white;
          border-radius: 1.5rem;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
          position: relative;
          z-index: 10;
        }
      </style>

      <h1 class="text-center text-tb-blue font-extrabold text-2xl md:text-3xl mb-16 tracking-wide uppercase drop-shadow-sm relative z-10">
        KULINER TAMBAK BAYAN
      </h1>

      <!-- Pawon Ko Edi -->
      <div class="flex justify-center mb-16 md:mb-20 relative z-10">
        <div class="menu-card w-full md:w-[600px] p-4 md:p-6">
          <div class="text-center mb-4">
            <h2 class="font-logo text-2xl text-tb-blue">Pawon</h2>
            <span class="bg-tb-red text-white text-xs px-2 py-1 rounded font-bold">Ko Edi</span>
          </div>
          <div class="w-28 h-28 mx-auto plate-pattern mb-4">
            <img src="/assets/KULINER/Mie Ayam.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Pawon Ko Edi">
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 text-sm">
            <div>
              <h3 class="text-tb-red font-bold mb-2">Menu Harian</h3>
              <ul class="space-y-1">
                <li class="flex justify-between"><span>Mie Ayam</span> <span class="font-bold">Rp15.000</span></li>
                <li class="flex justify-between"><span>Ayam Geprek</span> <span class="font-bold">Rp15.000</span></li>
                <li class="flex justify-between"><span>Mie Ayam Jamur</span> <span class="font-bold">Rp20.000</span></li>
              </ul>
              <h3 class="text-tb-red font-bold mt-3 mb-2">Menu Khusus Minggu</h3>
              <ul class="space-y-1">
                <li class="flex justify-between"><span>Penyet Telur</span> <span class="font-bold">Rp10.000</span></li>
                <li class="flex justify-between"><span>Penyet Ayam</span> <span class="font-bold">Rp15.000</span></li>
                <li class="flex justify-between"><span>Penyet Lele</span> <span class="font-bold">Rp15.000</span></li>
              </ul>
            </div>
            <div>
              <h3 class="text-tb-red font-bold mb-2">Minuman</h3>
              <ul class="space-y-1">
                <li class="flex justify-between"><span>Teh Jumbo</span> <span class="font-bold">Rp5.000</span></li>
                <li class="flex justify-between"><span>Teh Reguler</span> <span class="font-bold">Rp3.000</span></li>
                <li class="flex justify-between"><span>Es Kopyor</span> <span class="font-bold">Rp6.000</span></li>
                <li class="flex justify-between"><span>Es Blewah</span> <span class="font-bold">Rp5.000</span></li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Ai Cing Ai Katering -->
      <div class="flex justify-center mb-16 md:mb-24 relative z-10">
        <div class="menu-card w-full md:w-[600px] p-4 md:p-6">
          <div class="text-center mb-4">
            <h2 class="font-logo text-2xl text-tb-blue">Katering</h2>
            <span class="bg-tb-red text-white text-xs px-2 py-1 rounded font-bold">Ai Cing Ai</span>
          </div>
          <div class="w-28 h-28 mx-auto plate-pattern mb-4">
            <img src="/assets/KULINER/Siomay.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Katering Ai Cing Ai">
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 text-sm">
            <div>
              <h3 class="text-tb-blue font-bold mb-2">Makanan Ringan</h3>
              <ul class="space-y-1">
                <li class="flex justify-between"><span>Pa Kau Cu Ayam</span> <span class="font-bold">Rp5.000</span></li>
                <li class="flex justify-between"><span>Pa Kau Cu Babi</span> <span class="font-bold">Rp5.000</span></li>
                <li class="flex justify-between"><span>Siomay Babi</span> <span class="font-bold">Rp6.000</span></li>
                <li class="flex justify-between"><span>Yong Tahu Babi</span> <span class="font-bold">Rp6.000</span></li>
                <li class="flex justify-between"><span>Bakwan Goreng</span> <span class="font-bold">Rp6.000</span></li>
              </ul>
            </div>
            <div>
              <h3 class="text-tb-blue font-bold mb-2">Nasi Campur</h3>
              <ul class="space-y-1">
                <li class="flex justify-between"><span>+ Telur</span> <span class="font-bold">Rp15.000</span></li>
                <li class="flex justify-between"><span>+ Daging Sapi</span> <span class="font-bold">Rp15.000</span></li>
                <li class="flex justify-between"><span>+ Spesial + Ayam</span> <span class="font-bold">Rp20.000</span></li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Warung Pos & Warung Nasi Mak Bin -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-16 md:mb-24 relative z-10">
        <div class="menu-card p-4 md:p-5 text-center h-full flex flex-col justify-center">
          <h2 class="font-logo text-xl text-tb-blue">Warung Pos</h2>
          <span class="bg-tb-red text-white text-[10px] px-2 py-0.5 rounded font-bold block w-fit mx-auto mb-3">Ko Han</span>
          <div class="w-28 h-28 mx-auto plate-pattern mb-3">
            <img src="/assets/KULINER/Penyetan.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Warung Pos">
          </div>
          <ul class="text-sm space-y-1">
            <li class="flex justify-between"><span>Wedang Ronde</span><span class="font-bold">Rp12.000</span></li>
            <li class="flex justify-between"><span>Ote-Ote Udang</span><span class="font-bold">Rp2.500</span></li>
            <li class="flex justify-between"><span>Tahu Petis</span><span class="font-bold">Rp2.000</span></li>
          </ul>
        </div>
        <div class="menu-card p-4 md:p-5 text-center h-full flex flex-col justify-center">
          <div class="flex flex-col items-center">
            <h2 class="font-logo text-xl text-tb-blue">Warung Nasi</h2>
            <span class="bg-tb-red text-white text-[10px] px-2 py-0.5 rounded font-bold mb-3">Mak Bin</span>
          </div>
          <div class="w-28 h-28 mx-auto plate-pattern mb-3">
            <img src="/assets/KULINER/Penyetan.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Warung Nasi Mak Bin">
          </div>
          <ul class="text-sm space-y-1">
            <li class="flex justify-between md:flex-row-reverse md:gap-2"><span>Nasi Babi Kecap</span><span class="font-bold">Rp12.000</span></li>
            <li class="flex justify-between md:flex-row-reverse md:gap-2"><span>Nasi Krengseng Babi</span><span class="font-bold">Rp12.000</span></li>
            <li class="flex justify-between md:flex-row-reverse md:gap-2"><span>Tahu Petis</span><span class="font-bold">Rp2.000</span></li>
          </ul>
        </div>
      </div>

      <!-- Bu Lek Sunar + Tante Sum + Mak Han -->
      <div class="mb-16 md:mb-24 relative z-10">
        <div class="flex justify-center mb-8 relative z-30">
          <div class="menu-card p-4 md:p-6 w-full max-w-sm text-center shadow-lg">
            <h2 class="font-logo text-xl text-tb-blue">Ayam Panggang</h2>
            <span class="bg-tb-red text-white text-xs px-2 py-1 rounded font-bold mb-3 inline-block">Bu Lek Sunar</span>
            <p class="text-sm font-bold text-gray-600 mb-2">Nasi Ayam Panggang + Urap</p>
            <ul class="text-sm space-y-1 px-4">
              <li class="flex justify-between"><span>+ Ayam Potong</span><span class="font-bold">Rp20.000</span></li>
              <li class="flex justify-between"><span>+ Ayam Kampung</span><span class="font-bold">Rp30.000</span></li>
            </ul>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 -mt-4">
          <div class="menu-card p-4 md:p-5 text-center h-fit flex flex-col justify-center">
            <h2 class="font-logo text-xl text-tb-blue">Siomay</h2>
            <span class="bg-tb-red text-white text-[10px] px-2 py-0.5 rounded font-bold block w-fit mx-auto mb-3">Tante Sum</span>
            <div class="w-28 h-28 mx-auto plate-pattern mb-3">
              <img src="/assets/KULINER/Bakcang.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Siomay Tante Sum">
            </div>
            <ul class="text-sm space-y-1">
              <li class="flex justify-between"><span>Tiga Buah Siomay</span><span class="font-bold">Rp10.000</span></li>
            </ul>
          </div>
          <div class="menu-card p-4 md:p-5 text-center h-fit flex flex-col justify-center">
            <div class="flex flex-col items-center">
              <h2 class="font-logo text-xl text-tb-blue">Bakcang</h2>
              <span class="bg-tb-red text-white text-[10px] px-2 py-0.5 rounded font-bold mb-3">Mak Han</span>
            </div>
            <div class="w-28 h-28 mx-auto plate-pattern mb-3">
              <img src="/assets/KULINER/Bakcang.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Bakcang Mak Han">
            </div>
            <ul class="text-sm space-y-1">
              <li class="flex justify-between"><span>Bakcang Babi</span><span class="font-bold">Rp32.000</span></li>
              <li class="flex justify-between"><span>Bakcang Ayam</span><span class="font-bold">Rp32.000</span></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Tante Ika + Ve + Koes -->
      <div class="mb-16 md:mb-10 relative z-10">
        <div class="flex justify-center mb-8 relative z-30">
          <div class="menu-card p-4 md:p-6 w-full max-w-sm text-center shadow-lg">
            <h2 class="font-logo text-xl text-tb-blue">Penyetan</h2>
            <span class="bg-tb-red text-white text-xs px-2 py-1 rounded font-bold mb-3 inline-block">Tante Ika</span>
            <ul class="text-sm space-y-1 px-4 text-left">
              <li class="flex justify-between"><span>Nasi + Ayam Bakar</span><span class="font-bold">Rp20.000</span></li>
              <li class="flex justify-between"><span>Nasi + Bebek Bakar</span><span class="font-bold">Rp25.000</span></li>
              <li class="flex justify-between"><span>Nasi + Penyet Gurame</span><span class="font-bold">Rp20.000</span></li>
              <li class="flex justify-between"><span>Nasi + Penyet Mujaer</span><span class="font-bold">Rp15.000</span></li>
            </ul>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 -mt-4">
          <div class="menu-card p-4 md:p-5 text-center h-fit flex flex-col justify-center">
            <h2 class="font-logo text-xl text-tb-blue">Es Semangka</h2>
            <span class="bg-tb-red text-white text-[10px] px-2 py-0.5 rounded font-bold block w-fit mx-auto mb-3">Ve</span>
            <div class="w-28 h-28 mx-auto plate-pattern mb-3">
              <img src="/assets/KULINER/Es Semangka.webp" class="w-[90%] h-[90%] rounded-full object-cover border-4 border-white" alt="Es Semangka Ve">
            </div>
            <ul class="text-sm space-y-1">
              <li class="flex justify-between"><span>Es Semangka</span><span class="font-bold">Rp5.000</span></li>
            </ul>
          </div>
          <div class="menu-card p-4 md:p-5 text-center h-fit flex flex-col justify-center">
            <div class="flex flex-col items-center">
              <h2 class="font-logo text-xl text-tb-blue">Dapur</h2>
              <span class="bg-tb-red text-white text-[10px] px-2 py-0.5 rounded font-bold mb-3">Koes</span>
            </div>
            <ul class="text-sm space-y-1">
              <li class="flex justify-between"><span>Es Sinom (/botol)</span><span class="font-bold">Rp5.000</span></li>
            </ul>
          </div>
        </div>
      </div>

    </main>
    <Footer />
  </body>
</html>
