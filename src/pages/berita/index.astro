---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BeritaCard from "../../components/BeritaCard.astro";
---

<BaseLayout title="Berita - Tambak Bayan GO-WEB" description="Berita dan artikel terkini seputar Kampung Tambak Bayan, mural, dan komunitas.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <h1 class="text-center text-[#1E459F] font-bold text-2xl sm:text-3xl md:text-4xl mb-8 md:mb-12">
      ARTIKEL BERITA
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <BeritaCard
        imgSrc="/assets/berita/Berita_1.webp"
        title="Di Balik Tembok Mural Tambak Bayan: Perlawanan yang Tak Pernah Padam di Tengah Sengketa"
        href="https://www.ngopibareng.id/read-premium/di-balik-tembok-mural-tambak-bayan-perlawanan-yang-tak-pernah-padam-di-tengah-sengketa"
        reporter="Yunus Ar-Rahman"
        editor="Muh Hujain"
        date="Kamis, 14 Agustus 2025"
        excerpt="Warga Kampung Tambak Bayan berjuang mempertahankan tanah dan identitas mereka melalui mural dan kegiatan budaya di tengah sengketa lahan."
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_2.webp"
        title="HIMA MKSB UNAIR Sulut Kesadaran Budaya Melawan Penggusuran di Tambak Bayan"
        href="https://unair.ac.id/hima-mksb-unair-sulut-kesadaran-budaya-melawan-penggusuran-di-tambak-bayan/"
        reporter="Sintya Alfafa"
        editor="Ragil Kukuh Imanto"
        date="Kamis, 14 Agustus 2025"
        excerpt="HIMA MKSB Universitas Airlangga mengadakan kegiatan berbasis seni dan budaya untuk meningkatkan kesadaran publik sekaligus mendukung warga Kampung Tambak Bayan dalam menghadapi ancaman penggusuran."
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_3.webp"
        title="CULIT 2025 Ungkap Seni, Sejarah, dan Budaya di Kampung Pecinan Tambak Bayan Surabaya"
        href="https://harian.disway.id/read/891352/culit-2025-angkat-lagi-isu-sengketa-tanah-di-kampung-pecinan-tambak-bayan-surabaya"
        reporter="Ilmi Bening"
        editor="Guruh Dimas Nugraha"
        date="Rabu, 11 Agustus 2025"
        excerpt="Acara CULIT 2025 mengangkat kembali isu sengketa tanah antara warga Kampung Pecinan Tambak Bayan dan pihak Hotel Vini Vidi Vici sebagai upaya memperjuangkan hak serta sejarah komunitas lokal."
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_4.webp"
        title="Pameran Barang Bersejarah Koleksi Leluhur di Kampung Pecinan Tambak Bayan Surabaya"
        href="https://radarsurabaya.jawapos.com/hobi-lifestyle/775587147/pameran-barang-bersejarah-koleksi-leluhur-di-kampung-pecinan-tambak-bayan-surabaya"
        editor="Nurista Purnamasari"
        date="Kamis, 30 Januari 2025"
        excerpt={'Warga Kampung Pecinan Tambak Bayan menggelar pameran "Pameran Benda Biasa" yang menampilkan barang-barang peninggalan leluhur untuk melestarikan sejarah dan identitas kampung.'}
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_5.webp"
        title="Nostalgia Kehidupan Etnis Tionghoa di Kampung Tambak Bayan Surabaya"
        href="https://surabaya.kompas.com/read/2025/01/24/080406278/nostalgia-kehidupan-etnis-tionghoa-di-kampung-tambak-bayan-surabaya?page=all"
        reporter="Adhitiya Prasta Pratama"
        editor="Andi Hartik"
        date="Kamis, 24 Januari 2025"
        excerpt="Berita ini menyoroti kehidupan harmonis etnis Tionghoa dan Jawa di Kampung Tambak Bayan yang tetap menjaga tradisi dan warisan budaya di tengah modernisasi Surabaya."
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_6.webp"
        title="Sukacita Warga Tambak Bayan Sambut Imlek, Hias Kampung dengan Lampion"
        href="https://www.detik.com/jatim/budaya/d-7736181/sukacita-warga-tambak-bayan-sambut-imlek-hias-kampung-dengan-lampion"
        reporter="Aprilia Devi"
        date="Jumat, 17 Januari 2025"
        excerpt="Warga Kampung Tambak Bayan menyambut Imlek 2025 dengan menghias kampung memakai lampion dan menggelar pertunjukan barongsai."
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_7.webp"
        title="Mahasiswa UC Maknai Hari Pahlawan Lewat Mural di Kampung Tambak Bayan Surabaya"
        href="#artikel-7"
        reporter="Shohibul Anwar"
        date="Sabtu, 9 November 2024"
        excerpt="Mahasiswa VCD Universitas Ciputra Surabaya memperingati Hari Pahlawan dengan membuat mural di Kampung Tambak Bayan sebagai simbol semangat perjuangan sekaligus memperindah lingkungan kampung."
      />
      <BeritaCard
        imgSrc="/assets/berita/Berita_8.webp"
        title="'Travelling' ala Mahasiswa Vokasi di Perpustakaan Gedung Kuno Kampung Tambak Bayan Surabaya"
        href="https://unair.ac.id/post_fetcher/fakultas-vokasi-travelling-ala-mahasiswa-vokasi-di-perpustakaan-gedung-kuno-kampung-tambak-bayan-surabaya/"
        reporter="Ayisya Alexandra"
        editor="Oky Sapto Mugi Saputro"
        date="Sabtu, 22 Juni 2024"
        excerpt="Kegiatan mahasiswa FV UNAIR berupa kunjungan edukatif ke perpustakaan gedung kuno Kampung Tambak Bayan menjadi sarana pembelajaran budaya, pengabdian masyarakat, serta apresiasi terhadap warisan lokal."
      />
    </div>

    <!-- Pagination -->
    <nav class="flex justify-center items-center gap-2 mt-10 md:mt-14" aria-label="Pagination">
      <a href="/berita/" class="px-4 py-2.5 rounded-lg text-[#1E459F] font-medium bg-white border border-gray-200 hover:bg-[#1E459F]/10 transition-colors shadow-sm" aria-label="Halaman sebelumnya">
        <i class="fas fa-angles-left"></i>
      </a>
      <a href="/berita/" class="min-w-[2.75rem] py-2.5 rounded-lg bg-[#1E459F] text-white font-semibold text-center shadow-sm">1</a>
      <a href="/berita/halaman-2/" class="min-w-[2.75rem] py-2.5 rounded-lg text-[#1E459F] font-medium bg-white border border-gray-200 hover:bg-[#1E459F]/10 transition-colors text-center shadow-sm">2</a>
      <a href="/berita/halaman-3/" class="min-w-[2.75rem] py-2.5 rounded-lg text-[#1E459F] font-medium bg-white border border-gray-200 hover:bg-[#1E459F]/10 transition-colors text-center shadow-sm">3</a>
      <a href="/berita/halaman-2/" class="px-4 py-2.5 rounded-lg text-[#1E459F] font-medium bg-white border border-gray-200 hover:bg-[#1E459F]/10 transition-colors shadow-sm" aria-label="Halaman berikutnya">
        <i class="fas fa-angles-right"></i>
      </a>
    </nav>
  </section>
</BaseLayout>
