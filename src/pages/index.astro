---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Tambak Bayan GO-WEB - Beranda">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

  <style>
    .welcome-watermark {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 140px;
      pointer-events: none;
      overflow: visible;
    }
    .welcome-watermark .label {
      position: absolute;
      left: 0;
      top: 6%;
      width: 100%;
      max-width: none;
      padding: 0 1rem;
      pointer-events: none;
      overflow: visible;
    }
    .welcome-watermark .label .text-wrapper {
      display: block;
      white-space: nowrap;
      text-align: left;
      font-weight: 800;
      color: #b92e2b;
      opacity: 0.50;
      font-size: clamp(22px, 5vw, 72px);
      letter-spacing: 0.5px;
      line-height: 1;
      margin-bottom: 1rem;
      overflow: visible;
    }
    @media (max-width: 640px) {
      .welcome-watermark { bottom: 120px; }
      .welcome-watermark .label { top: 6%; width: 150%; }
      .welcome-watermark .label .text-wrapper {
        font-size: clamp(16px, 6vw, 36px);
        margin-bottom: 0.8rem;
      }
    }
  </style>

  <!-- Hero Section -->
  <section class="relative w-full overflow-hidden px-4 sm:px-6 pt-4 pb-0" aria-label="Photo slideshow">
    <div class="max-w-7xl mx-auto">
      <div class="relative aspect-[21/9] sm:aspect-[3/1] md:aspect-[21/8] overflow-hidden rounded-[40px]">
        <div class="slides-track flex absolute inset-0 transition-transform duration-500 ease-out" style="width: 600%;">
          <div class="slide flex-shrink-0 w-1/6 relative h-full">
            <img src="/assets/beranda/Beranda_1.webp" alt="Beranda 1" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" />
          </div>
          <div class="slide flex-shrink-0 w-1/6 relative h-full">
            <img src="/assets/beranda/Beranda_2.webp" alt="Beranda 2" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
          </div>
          <div class="slide flex-shrink-0 w-1/6 relative h-full">
            <img src="/assets/beranda/Beranda_3.webp" alt="Beranda 3" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
          </div>
          <div class="slide flex-shrink-0 w-1/6 relative h-full">
            <img src="/assets/beranda/Beranda_4.webp" alt="Beranda 4" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
          </div>
          <div class="slide flex-shrink-0 w-1/6 relative h-full">
            <img src="/assets/beranda/Beranda_5.webp" alt="Beranda 5" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
          </div>
          <div class="slide flex-shrink-0 w-1/6 relative h-full">
            <img src="/assets/beranda/Beranda_6.webp" alt="Beranda 6" class="absolute inset-0 w-full h-full object-cover object-center" loading="lazy" />
          </div>
        </div>
        <button type="button" class="slide-prev absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white flex items-center justify-center text-tb-blue shadow-lg transition-all" aria-label="Foto sebelumnya">
          <i class="fas fa-chevron-left text-lg"></i>
        </button>
        <button type="button" class="slide-next absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white flex items-center justify-center text-tb-blue shadow-lg transition-all" aria-label="Foto berikutnya">
          <i class="fas fa-chevron-right text-lg"></i>
        </button>
      </div>
      <div class="slide-indicators flex justify-center gap-2 py-3" role="tablist" aria-label="Indikator slide">
        <button type="button" class="indicator w-2 h-2 rounded-full bg-tb-blue/60 hover:bg-tb-blue transition-colors indicator-active" aria-label="Slide 1" role="tab"></button>
        <button type="button" class="indicator w-2 h-2 rounded-full bg-tb-blue/30 hover:bg-tb-blue transition-colors" aria-label="Slide 2" role="tab"></button>
        <button type="button" class="indicator w-2 h-2 rounded-full bg-tb-blue/30 hover:bg-tb-blue transition-colors" aria-label="Slide 3" role="tab"></button>
        <button type="button" class="indicator w-2 h-2 rounded-full bg-tb-blue/30 hover:bg-tb-blue transition-colors" aria-label="Slide 4" role="tab"></button>
        <button type="button" class="indicator w-2 h-2 rounded-full bg-tb-blue/30 hover:bg-tb-blue transition-colors" aria-label="Slide 5" role="tab"></button>
        <button type="button" class="indicator w-2 h-2 rounded-full bg-tb-blue/30 hover:bg-tb-blue transition-colors" aria-label="Slide 6" role="tab"></button>
      </div>
    </div>
  </section>

  <!-- Slogan -->
  <section class="w-full py-6 md:py-10 px-4 text-center" id="beranda">
    <h1 class="max-w-4xl mx-auto font-bold text-tb-red text-2xl sm:text-3xl md:text-4xl leading-tight">
      Tanah Kami, Hak Kami, Suara Kami.
    </h1>
  </section>

  <!-- Welcome Section -->
  <section class="relative w-full overflow-hidden py-10 md:py-16 px-4 sm:px-6">
    <div class="welcome-watermark absolute inset-0 overflow-hidden pointer-events-none select-none" aria-hidden="true">
      <div class="label" role="banner" aria-label="Welcome banner">
        <p class="text-wrapper">SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN</p>
        <p class="text-wrapper">SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN</p>
        <p class="text-wrapper">SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN</p>
        <p class="text-wrapper">SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN SELAMAT DATANG DI TAMBAK BAYAN</p>
      </div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto">
      <div class="relative min-h-[160px] sm:min-h-[200px] md:min-h-[260px] mb-8 md:mb-12">
        <img src="/assets/beranda/Beranda_Elemen 4.webp" alt="" class="absolute w-24 h-32 sm:w-28 sm:h-36 md:w-36 md:h-44 object-cover rounded shadow-lg -rotate-[5deg] top-0 left-0 md:left-4 border-2 border-[#B92E2B]/30" loading="lazy" />
        <img src="/assets/beranda/Beranda_Elemen 1.webp" alt="" class="absolute w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28 object-cover rounded-full shadow-lg rotate-[6deg] top-2 left-1/2 -translate-x-1/2 md:left-[45%] md:translate-x-0 border-2 border-[#B92E2B]/30" loading="lazy" />
        <img src="/assets/beranda/Beranda_Elemen 2.webp" alt="" class="absolute w-16 h-20 sm:w-20 sm:h-24 md:w-24 md:h-28 object-cover rounded shadow-lg rotate-[2deg] top-0 right-2 md:right-8 border-2 border-[#B92E2B]/30" loading="lazy" />
        <img src="/assets/beranda/Beranda_Elemen 3.webp" alt="" class="absolute w-20 h-16 sm:w-24 sm:h-20 md:w-28 md:h-24 object-cover rounded shadow-lg -rotate-[8deg] bottom-0 right-4 md:right-16 border-2 border-[#B92E2B]/30" loading="lazy" />
      </div>

      <div class="relative z-20 text-center">
        <a href="/tentang-kami/" class="inline-block px-8 py-4 md:px-12 md:py-5 rounded-full bg-[#B92E2B] text-[#EEBB3B] font-semibold text-base md:text-lg shadow-lg hover:bg-[#5c2908] focus:outline-none focus:ring-2 focus:ring-tb-beige transition-all">
          Yuk Kenali Tambak Bayan!
        </a>
      </div>
    </div>
  </section>

  <!-- Chinese Greetings -->
  <section class="relative w-full py-14 md:py-20 px-6 sm:px-8 min-h-[200px]" aria-label="Sapaan dalam bahasa Mandarin">
    <div class="max-w-5xl mx-auto relative flex flex-wrap justify-center items-center gap-x-12 gap-y-8 sm:gap-x-16 sm:gap-y-10 min-h-[180px]">
      <span class="font-semibold text-xl sm:text-2xl md:text-3xl text-[#fbbf24]">欢迎!</span>
      <span class="font-semibold text-lg sm:text-xl md:text-2xl text-[#f59e0b]">早上好</span>
      <span class="font-semibold text-lg sm:text-2xl text-[#eab308]">晚安</span>
      <span class="font-semibold text-xl md:text-2xl text-[#d97706]">下午好</span>
      <span class="font-semibold text-lg sm:text-2xl text-[#b45309]">谢谢</span>
      <span class="font-semibold text-xl sm:text-2xl md:text-3xl text-[#fbbf24]">再见</span>
    </div>
  </section>

  <script>
    (function () {
      var track = document.querySelector('.slides-track');
      var indicators = document.querySelectorAll('.slide-indicators .indicator');
      var prev = document.querySelector('.slide-prev');
      var next = document.querySelector('.slide-next');
      if (!track || !indicators.length) return;
      var current = 0;
      var total = indicators.length;
      function update() {
        track.style.transform = 'translateX(-' + current * (100 / total) + '%)';
        indicators.forEach(function (el, i) {
          el.classList.toggle('indicator-active', i === current);
          el.classList.toggle('bg-tb-blue/60', i === current);
          el.classList.toggle('bg-tb-blue/30', i !== current);
        });
      }
      if (next) next.addEventListener('click', function () { current = (current + 1) % total; update(); });
      if (prev) prev.addEventListener('click', function () { current = (current - 1 + total) % total; update(); });
      indicators.forEach(function (el, i) {
        el.addEventListener('click', function () { current = i; update(); });
      });
      setInterval(function () { current = (current + 1) % total; update(); }, 5000);
    })();
  </script>
</BaseLayout>
