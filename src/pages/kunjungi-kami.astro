---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kunjungi Kami - Tambak Bayan GO-WEB" description="Lokasi dan media sosial Institut Seni Tambak Bayan.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 space-y-10 md:space-y-14">
    <!-- Google Maps -->
    <section>
      <h1 class="text-[#B92E2B] font-bold text-xl sm:text-2xl md:text-3xl mb-4 md:mb-6">
        Peta Lokasi (GMaps)
      </h1>
      <a href="https://maps.app.goo.gl/mW5gzKq7QU7jjZYP8" target="_blank" rel="noopener noreferrer"
        class="map-hover group block rounded-2xl overflow-hidden shadow-lg transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:ring-4 hover:ring-[#B92E2B]/30 focus:outline-none focus:ring-4 focus:ring-[#B92E2B]/40">
        <div class="relative aspect-video md:aspect-[21/9] bg-gray-200">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3957.3934789!2d112.7450!3d-7.2575!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7f96f3b3b3b3b%3A0x3b3b3b3b3b3b3b3b!2sTambak%20Bayan!5e0!3m2!1sen!2sid!4v1234567890"
            class="absolute inset-0 w-full h-full pointer-events-none" style="border:0;" allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="Peta Lokasi Tambak Bayan"></iframe>
          <div class="absolute inset-0 bg-black/20 pointer-events-none flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <span class="bg-[#B92E2B] text-white px-4 py-2 rounded-lg font-semibold text-sm shadow-lg">Buka di Google Maps</span>
          </div>
        </div>
      </a>
      <p class="mt-4 text-[#B92E2B] font-medium text-sm sm:text-base md:text-lg">
        Jl. Tambak Bayan Tengah No.39-41, Alun-alun Contong, Bubutan, Surabaya, East Java 60174
      </p>
    </section>

    <!-- Instagram Card -->
    <section>
      <h2 class="text-[#B92E2B] font-bold text-xl sm:text-2xl md:text-3xl mb-6 md:mb-8">
        Kunjungi Sosial Media Kami!
      </h2>
      <div class="bg-white rounded-2xl md:rounded-3xl shadow-xl p-6 md:p-8">
        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-center md:items-start">
          <div class="flex-shrink-0 flex flex-col items-center text-center pt-4 md:pt-8">
            <div class="w-36 h-36 md:w-48 md:h-48 rounded-full overflow-hidden border-4 border-[#B92E2B]/20 shadow-md bg-gray-100">
              <img src="/assets/kunjungi-kami/logo istb.webp" alt="Institut Seni Tambak Bayan" class="w-full h-full object-cover" />
            </div>
            <p class="mt-4 text-[#B92E2B] font-black text-base sm:text-lg text-center">
              INSTITUT SENI TAMBAK BAYAN
            </p>
          </div>
          <div class="flex-1 min-w-0 text-center md:text-left">
            <h3 class="text-[#B92E2B] font-bold text-lg sm:text-xl">institutsenitambakbayan</h3>
            <p class="text-gray-600 text-sm sm:text-base">INSTITUT SENI TAMBAK BAYAN (ISTB)</p>
            <div class="flex justify-center md:justify-start gap-8 mt-4">
              <div class="text-center">
                <span class="block font-bold text-[#B92E2B] text-lg">168</span>
                <span class="text-gray-500 text-sm">Kiriman</span>
              </div>
              <div class="text-center">
                <span class="block font-bold text-[#B92E2B] text-lg">1.624</span>
                <span class="text-gray-500 text-sm">Pengikut</span>
              </div>
              <div class="text-center">
                <span class="block font-bold text-[#B92E2B] text-lg">173</span>
                <span class="text-gray-500 text-sm">Diikuti</span>
              </div>
            </div>
            <div class="mt-5 pt-4 border-t border-gray-200">
              <p class="text-gray-500 text-xs font-semibold uppercase tracking-wide">Komunitas</p>
              <p class="text-[#B92E2B] font-medium text-sm sm:text-base mt-1 leading-relaxed">
                <strong>INSTITUT SENI TAMBAK BAYAN</strong><br />
                WADAH PERJUANGAN WARGA TAMBAK BAYAN<br />
                DARI PERAMPASAN RUANG HIDUP
              </p>
            </div>
          </div>
        </div>
        <div class="mt-6 md:mt-8 text-center">
          <a href="https://www.instagram.com/institutsenitambakbayan/" target="_blank" rel="noopener noreferrer"
            class="inline-block w-full sm:w-auto px-8 py-3 rounded-xl bg-[#B92E2B] text-white font-bold text-sm sm:text-base uppercase tracking-wide shadow-md transition-all duration-300 hover:scale-105 hover:bg-[#9a2624] focus:outline-none focus:ring-4 focus:ring-[#B92E2B]/40">
            KUNJUNGI KAMI
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
