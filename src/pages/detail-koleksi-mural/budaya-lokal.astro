---
import BaseHead from "../../components/BaseHead.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import MuralCard from "../../components/MuralCard.astro";
import "../../styles/global.css";
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <BaseHead title="Tambak Bayan GO-WEB - Mural Budaya Lokal" description="Koleksi Mural Budaya Lokal Tambak Bayan." />
    <style>
      @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(32px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body class="font-sans antialiased text-gray-900 min-h-screen">
    <main class="w-full min-h-screen overflow-x-hidden" style="background: linear-gradient(180deg, #EEBB3B 0%, #e0a020 30%, #c96418 65%, #B92E2B 100%);">
      <Navbar />

      <section class="w-full pt-10 pb-2 text-center px-5">
        <h1 class="font-bold text-[#1E459F] text-2xl sm:text-3xl md:text-4xl tracking-wide drop-shadow-sm" style="animation: fadeSlideUp 0.4s ease both;">
          Budaya Lokal
        </h1>
        <div class="mx-auto mt-3 w-16 h-1 rounded-full bg-[#1E459F]/60"></div>
      </section>

      <section class="w-full px-6 sm:px-10 md:px-16 lg:px-20" aria-label="Koleksi Mural Budaya Lokal">
        <div class="max-w-4xl mx-auto" style="display: flex; flex-direction: column; gap: 60px; padding: 40px 0;">
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_1.webp" alt="Mural Budaya Lokal 1"
            title="Membangun Harapan" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Mural berisi gambar orang yang sedang membangun dan melukis. Hal ini mencerminkan proses kreatif dan semangat warga Tambak Bayan dalam membangun dan memperindah kampung mereka melalui seni mural." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_2.webp" alt="Mural Budaya Lokal 2"
            title="Bingkai Harapan" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Mural yang digambarkan dengan ilustrasi tangan dan sebuah kamera yang menjadi simbol bahwa setiap sudut Tambak Bayan layak untuk diabadikan." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_3.webp" alt="Mural Budaya Lokal 3"
            title="Tiga Serangkai" artist="Pelukis" year="2024"
            description="Tiga anak kecil sedang memegang sebuah layang-layang. Hal ini mencerminkan kegembiraan dan kebebasan yang dirasakan oleh anak-anak di Tambak Bayan." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_4.webp" alt="Mural Budaya Lokal 4"
            title="Bersama Dalam Keberagaman" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Ilustrasi dua orang yang sedang bergandengan tangan. Hal ini menunjukkan kekompakan dan semangat persatuan di antara warga Kampung Tambak Bayan dalam menghadapi segala tantangan." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_5.webp" alt="Mural Budaya Lokal 5"
            title="Harapan yang Bersemi" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Mural bergambar seorang perempuan yang sedang memegang bunga. Bunga tersebut melambangkan harapan, ketahanan, dan keindahan yang tumbuh di tengah kesulitan." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_6.webp" alt="Mural Budaya Lokal 6"
            title="Pencak Silat" artist="Warga Tambak Bayan" year="2024"
            description="Menggambarkan seni bela diri pencak silat yang merupakan warisan budaya Indonesia dan menjadi identitas Kampung Tambak Bayan dalam melestarikan tradisi leluhur." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_7.webp" alt="Mural Budaya Lokal 7"
            title="Bersama Melawan" artist="Warga Tambak Bayan" year="2024"
            description="Visual sekelompok orang yang bersatu padu. Melambangkan semangat kolektif warga Kampung Tambak Bayan dalam mempertahankan hak dan tanah mereka." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_8.webp" alt="Mural Budaya Lokal 8"
            title="Merawat Budaya" artist="Warga Tambak Bayan" year="2024"
            description="Mural ini menggambarkan komitmen warga Tambak Bayan dalam merawat dan melestarikan budaya lokal di tengah arus modernisasi." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_9.webp" alt="Mural Budaya Lokal 9"
            title="Warisan Leluhur" artist="Warga Tambak Bayan" year="2024"
            description="Mural yang menampilkan motif-motif tradisional sebagai pengingat akan kekayaan warisan budaya yang harus dijaga oleh generasi penerus." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_10.webp" alt="Mural Budaya Lokal 10"
            title="Kampungku" artist="Warga Tambak Bayan" year="2024"
            description="Penggambaran suasana kampung yang asri dan penuh warna, merepresentasikan kecintaan warga terhadap lingkungan tempat tinggal mereka." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_11.webp" alt="Mural Budaya Lokal 11"
            title="Jejak Langkah" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Mural yang menceritakan perjalanan panjang warga Tambak Bayan dalam mempertahankan kampung halaman mereka melalui jejak-jejak langkah yang tertinggal." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_12.webp" alt="Mural Budaya Lokal 12"
            title="Semangat Gotong Royong" artist="Warga Tambak Bayan" year="2024"
            description="Visual yang menggambarkan semangat gotong royong warga yang menjadi fondasi kekuatan komunitas Tambak Bayan." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_13.webp" alt="Mural Budaya Lokal 13"
            title="Akulturasi Budaya" artist="Pelukis" year="2024"
            description="Mural yang merepresentasikan akulturasi budaya Tionghoa dan Jawa yang telah lama terjalin di Kampung Tambak Bayan." />
          <MuralCard src="/assets/koleksi-mural/budaya-lokal/BL_14.webp" alt="Mural Budaya Lokal 14"
            title="Harapan Baru" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Sebuah mural yang melambangkan harapan baru bagi masa depan Kampung Tambak Bayan yang lebih cerah." />
        </div>
      </section>

      <Footer />
    </main>
  </body>
</html>
