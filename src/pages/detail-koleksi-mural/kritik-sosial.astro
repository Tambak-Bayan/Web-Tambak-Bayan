---
import BaseHead from "../../components/BaseHead.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import MuralCard from "../../components/MuralCard.astro";
import "../../styles/global.css";
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <BaseHead title="Tambak Bayan GO-WEB - Mural Kritik Sosial" description="Koleksi Mural Kritik Sosial Tambak Bayan." />
    <style>
      @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(32px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body class="font-sans antialiased text-gray-900 min-h-screen">
    <main class="w-full min-h-screen overflow-x-hidden" style="background: linear-gradient(180deg, #EEBB3B 0%, #e0a020 30%, #c96418 65%, #B92E2B 100%);">
      <Navbar />

      <section class="w-full pt-10 pb-2 text-center px-5">
        <h1 class="font-bold text-[#1E459F] text-2xl sm:text-3xl md:text-4xl tracking-wide drop-shadow-sm" style="animation: fadeSlideUp 0.4s ease both;">
          Kritik Sosial
        </h1>
        <div class="mx-auto mt-3 w-16 h-1 rounded-full bg-[#1E459F]/60"></div>
      </section>

      <section class="w-full px-6 sm:px-10 md:px-16 lg:px-20" aria-label="Koleksi Mural Kritik Sosial">
        <div class="max-w-4xl mx-auto" style="display: flex; flex-direction: column; gap: 80px; padding: 40px 0;">
          <MuralCard
            src="/assets/koleksi-mural/kritik-sosial/KS_1.webp" alt="Mural Kritik Sosial 1"
            title="Karya Tim OHS" artist="Prof. Kenta, Mas Bintang, & Mas Pandu" year="2011"
            eager={true}
            description="Gambar naga memakan ekornya sendiri menggambarkan seorang keturunan Tionghoa memangsa bangsanya sendiri. Menunjukkan kritik atas sengketa tanah yang terjadi antara Kampung Tambak Bayan dengan Hotel V3."
          />
          <MuralCard
            src="/assets/koleksi-mural/kritik-sosial/KS_2.webp" alt="Mural Kritik Sosial 2"
            title="Karya Tim OHS" artist="Prof. Kenta, Pak Kumara, Mas Bintang, & Mas Pandu" year="2011"
            description="Lukisan rumah kayu ini merupakan mural pertama dan diinisiasi oleh tim OHS yang saat itu tengah melakukan penelitian terhadap kampung-kampung di Surabaya. Sehingga saat mengetahui terdapat masalah sengketa antara Kampung Tambak Bayan dengan Hotel V3, Prof. Kenta selaku peneliti menganggap bahwa mural dapat menjadi seni monumental yang dapat mempertahankan kawasan tersebut."
          />
          <MuralCard
            src="/assets/koleksi-mural/kritik-sosial/KS_3.webp" alt="Mural Kritik Sosial 3"
            title="Karya Tim OHS" artist="Prof. Kenta, Pak Kumara, Mas Bintang, & Mas Pandu" year="2011"
            description={'Mural yang berisi tulisan "Jari Takkan Patahkan Kayu" yang berarti seseorang tidak dapat melakukan hal yang tidak sesuai dengan kemampuannya.'}
          />
          <MuralCard
            src="/assets/koleksi-mural/kritik-sosial/KS_4.webp" alt="Mural Kritik Sosial 4"
            title="Karya Kelompok Mahasiswa UC" artist="Mahasiswa Universitas Ciputra" year="2024"
            description="Mural bercerita tentang karya dari mbak Pinky tentang lampion yang dibuat dari fotocopy hasil keputusan dengan tali lampion yang diputus sehingga menggambarkan kalau harapan itu akan selalu ada karena lampion akan melambung tinggi."
          />
        </div>
      </section>

      <Footer />
    </main>
  </body>
</html>
