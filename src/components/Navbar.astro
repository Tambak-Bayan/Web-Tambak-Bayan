---
const currentPath = Astro.url.pathname;

interface NavLink {
  name: string;
  href: string;
  matchPattern?: string;
}

const navLinks: NavLink[] = [
  { name: "Beranda", href: "/" },
  { name: "Tentang Kami", href: "/tentang-kami/" },
  { name: "Berita", href: "/berita/" },
  { name: "Kunjungi Kami", href: "/kunjungi-kami/" },
  { name: "Agenda", href: "/agenda/" },
  { name: "Kuliner", href: "/kuliner/" },
  { name: "Merchandise", href: "/merchandise/" },
  { name: "Koleksi Mural", href: "/koleksi-mural/", matchPattern: "koleksi-mural" },
];

function isActive(link: NavLink): boolean {
  if (link.href === "/") {
    return currentPath === "/" || currentPath === "/index.html";
  }
  if (link.matchPattern) {
    return currentPath.includes(link.matchPattern);
  }
  return currentPath.startsWith(link.href);
}
---

<style>
  #main-nav {
    transition: max-height 0.35s ease-out, opacity 0.3s ease-out, transform 0.3s ease-out, visibility 0.3s ease-out;
  }
  @media (max-width: 767px) {
    #main-nav {
      max-height: 0;
      opacity: 0;
      transform: translateY(-10px);
      overflow: hidden;
      visibility: hidden;
    }
    #main-nav.open {
      max-height: 520px;
      opacity: 1;
      transform: translateY(0);
      visibility: visible;
    }
    #main-nav.open + #nav-backdrop {
      opacity: 1;
      visibility: visible;
    }
    #nav-backdrop {
      transition: opacity 0.3s ease-out, visibility 0.3s ease-out;
      opacity: 0;
      visibility: hidden;
    }
    #menu-toggle.open span:nth-child(1) {
      transform: rotate(45deg) translate(4px, 4px);
    }
    #menu-toggle.open span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }
    #menu-toggle.open span:nth-child(3) {
      transform: rotate(-45deg) translate(4px, -4px);
    }
  }
</style>

<header class="w-full bg-[#EEBB3B] border-b border-[#B92E2B]/20 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 md:py-4 flex flex-wrap items-center justify-between gap-3">
    <a href="/" class="flex-shrink-0 inline-flex items-center group">
      <img src="/assets/beranda/logo.webp" alt="Tambak Bayan logo" class="h-10 sm:h-12 md:h-14 object-contain group-hover:scale-105 transition-transform duration-300" />
    </a>

    <button id="menu-toggle" type="button" class="md:hidden flex flex-col gap-1.5 p-3 rounded-lg hover:bg-[#B92E2B]/10 transition-colors min-w-[44px] min-h-[44px] items-center justify-center" aria-label="Toggle menu" aria-expanded="false">
      <span class="block w-6 h-0.5 bg-[#78350f] rounded-full transition-all duration-300 origin-center"></span>
      <span class="block w-6 h-0.5 bg-[#78350f] rounded-full transition-all duration-300 origin-center"></span>
      <span class="block w-6 h-0.5 bg-[#78350f] rounded-full transition-all duration-300 origin-center"></span>
    </button>

    <div id="nav-backdrop" class="fixed inset-0 bg-black/40 z-40 md:hidden"></div>

    <nav id="main-nav" class="w-full md:w-auto order-3 md:order-none basis-full md:basis-auto" aria-label="Navigasi utama">
      <ul class="flex flex-col md:flex-row items-center gap-3 md:gap-0 py-3 md:py-0 list-none m-0 p-0">
        {
          navLinks.map((link) => {
            const active = isActive(link);
            const activeClass = active
              ? "text-[#1E459F] font-bold border-b-2 border-[#1E459F] pointer-events-none"
              : "text-[#78350f] font-semibold hover:text-[#CF2A2A]";
            return (
              <li class="border-r border-[#78350f]/30 md:pr-3 md:pl-3 first:pl-0 w-full md:w-auto text-center md:text-left">
                <a href={link.href} class={`${activeClass} transition-colors text-sm block py-3 md:py-0 min-h-[44px] md:min-h-0 flex items-center justify-center`}>
                  {link.name}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  (function () {
    var toggle = document.getElementById('menu-toggle');
    var nav = document.getElementById('main-nav');
    var backdrop = document.getElementById('nav-backdrop');
    if (!toggle || !nav || !backdrop) return;

    function openMenu() {
      nav.classList.add('open');
      toggle.classList.add('open');
      backdrop.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      nav.classList.remove('open');
      toggle.classList.remove('open');
      backdrop.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', function () {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      expanded ? closeMenu() : openMenu();
    });

    nav.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });

    backdrop.addEventListener('click', closeMenu);
  })();
</script>
