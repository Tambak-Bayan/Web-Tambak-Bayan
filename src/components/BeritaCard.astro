---
interface Props {
  imgSrc: string;
  imgAlt?: string;
  title: string;
  href: string;
  reporter?: string;
  editor?: string;
  date: string;
  excerpt: string;
}

const { imgSrc, imgAlt = "", title, href, reporter, editor, date, excerpt } = Astro.props;
---

<article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-lg transition-shadow flex flex-col sm:flex-row">
  <a href={href} class="sm:w-40 sm:flex-shrink-0 block aspect-video sm:aspect-square">
    <img src={imgSrc} alt={imgAlt} class="w-full h-full object-cover" loading="lazy" />
  </a>
  <div class="p-4 sm:p-5 flex flex-col flex-1 min-w-0">
    <h2 class="text-[#1E459F] font-bold text-base sm:text-lg leading-snug line-clamp-2">
      <a href={href} class="hover:underline">{title}</a>
    </h2>
    <div class="mt-2 text-gray-500 text-xs sm:text-sm space-y-0.5">
      {reporter && <p><i class="fas fa-user w-4 text-center"></i> {reporter}{editor && <span> l Editor: {editor}</span>}</p>}
      <p><i class="fas fa-calendar-alt w-4 text-center"></i> {date}</p>
    </div>
    <p class="mt-3 text-gray-600 text-sm line-clamp-3 flex-1">{excerpt}</p>
    <a href={href} class="mt-3 inline-flex items-center gap-1 text-[#1E459F] font-semibold text-sm hover:underline self-end">
      Lihat Selengkapnya <i class="fas fa-arrow-right text-xs"></i>
    </a>
  </div>
</article>
