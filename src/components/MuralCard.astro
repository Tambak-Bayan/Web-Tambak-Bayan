---
interface Props {
  src: string;
  alt: string;
  title: string;
  artist: string;
  year: string;
  description: string;
  eager?: boolean;
}

const { src, alt, title, artist, year, description, eager = false } = Astro.props;
---

<div class="mural-card">
  <div class="card-photo-col">
    <img src={src} alt={alt} loading={eager ? "eager" : "lazy"} />
  </div>
  <div class="card-text-col">
    <h2 class="font-bold text-gray-900 text-xl sm:text-2xl leading-snug">{title}</h2>
    <p class="text-sm text-gray-400 font-medium">{artist} &nbsp;&bull;&nbsp; {year}</p>
    <p class="text-gray-700 text-sm sm:text-[0.95rem] leading-relaxed text-justify hyphens-auto">{description}</p>
  </div>
</div>

<style>
  .mural-card {
    position: relative;
    overflow: visible;
    display: flex;
    flex-direction: row;
    align-items: center;
    min-height: 180px;
    animation: fadeSlideUp 0.6s ease both;
    transition: transform 0.3s ease;
  }
  .mural-card:hover {
    transform: translateY(-5px);
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(32px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mural-card::before {
    content: '';
    position: absolute;
    left: calc(500px - 80px);
    right: 0;
    top: 0;
    bottom: 0;
    background: #ffffff;
    border-radius: 1rem;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.14);
    transition: box-shadow 0.3s ease;
    z-index: 0;
  }
  .mural-card:hover::before {
    box-shadow: 0 18px 52px rgba(0, 0, 0, 0.22);
  }

  .card-photo-col {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    width: 500px;
  }
  .card-photo-col img {
    display: block;
    width: 500px;
    height: 280px;
    object-fit: cover;
    object-position: center;
    border-radius: 1rem;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.45), 0 4px 14px rgba(0, 0, 0, 0.26);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .mural-card:hover .card-photo-col img {
    transform: scale(1.03);
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.52), 0 6px 18px rgba(0, 0, 0, 0.32);
  }

  .card-text-col {
    position: relative;
    z-index: 1;
    flex: 1;
    padding: 28px 32px 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (max-width: 639px) {
    .mural-card {
      flex-direction: column;
      align-items: stretch;
    }
    .mural-card::before {
      left: 0;
      right: 0;
      top: 80px;
      bottom: 0;
    }
    .card-photo-col {
      width: 100%;
      margin-top: 0;
      margin-bottom: 0;
      padding: 0 16px;
    }
    .card-photo-col img {
      width: 100%;
      height: 200px;
      border-radius: 0.875rem;
    }
    .card-text-col {
      width: 100%;
      padding: 16px 20px 24px;
      word-break: break-word;
      overflow-wrap: break-word;
    }
    .card-text-col p {
      text-align: left !important;
      hyphens: none !important;
    }
  }

  @media (min-width: 640px) and (max-width: 767px) {
    .card-photo-col {
      width: 220px;
    }
    .card-photo-col img {
      width: 220px;
      height: 220px;
    }
    .mural-card::before {
      left: calc(220px - 50px);
    }
    .card-text-col {
      padding: 20px 20px 20px 16px;
    }
  }
</style>
